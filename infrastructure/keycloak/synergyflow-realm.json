{
  "id": "synergyflow",
  "realm": "synergyflow",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator with full system access"
      },
      {
        "name": "itsm_agent",
        "description": "ITSM Agent for ticket and incident management operations"
      },
      {
        "name": "developer",
        "description": "Developer for project management and issue tracking operations"
      },
      {
        "name": "manager",
        "description": "Manager for approval workflow operations"
      },
      {
        "name": "employee",
        "description": "Employee for self-service request submission"
      }
    ]
  },
  "clients": [
    {
      "clientId": "synergyflow-backend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "synergyflow-secret-change-in-production",
      "redirectUris": [
        "http://localhost:8081/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8081"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@test.com",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "realmRoles": [
        "admin"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ]
    },
    {
      "username": "agent1",
      "enabled": true,
      "email": "agent1@test.com",
      "emailVerified": true,
      "firstName": "Agent",
      "lastName": "One",
      "realmRoles": [
        "itsm_agent"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "agent123",
          "temporary": false
        }
      ]
    },
    {
      "username": "dev1",
      "enabled": true,
      "email": "dev1@test.com",
      "emailVerified": true,
      "firstName": "Developer",
      "lastName": "One",
      "realmRoles": [
        "developer"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "dev123",
          "temporary": false
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "role_list",
    "profile",
    "email",
    "roles",
    "web-origins",
    "acr"
  ],
  "requiredCredentials": [
    "password"
  ],
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000
}
