# SynergyFlow Backend Environment Variables
# Copy this file to .env and update values for your environment

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synergyflow
DB_USERNAME=synergyflow
DB_PASSWORD=synergyflow

# SSL Configuration
# Options: disable, allow, prefer, require, verify-ca, verify-full
# Development: prefer (attempts SSL, falls back to non-SSL)
# Production: require or verify-full
SSL_MODE=prefer

# Note: Never commit .env file to version control
# Add .env to .gitignore to prevent credential leaks
